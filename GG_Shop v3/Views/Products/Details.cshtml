@{
    ViewBag.Title = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
}

<div class="content-page">
    <div class="container-fluid">
        <h2>Chi tiết sản phẩm</h2>

        <div class="row">

            <!-- LEFT: PRODUCT INFO -->
            <div class="col-md-8">
                <h4>Thông tin chung</h4>
                <hr />

                <dl class="dl-horizontal">
                    <dt>Danh mục sản phẩm</dt>
                    <dd id="d-category">Đang tải...</dd>

                    <dt>Tên sản phẩm</dt>
                    <dd id="d-title">Đang tải...</dd>

                    <dt>Mô tả</dt>
                    <dd id="d-description">Đang tải...</dd>

                    <dt>Trạng thái</dt>
                    <dd id="d-status">Đang tải...</dd>
                </dl>

                <p>
                    <a id="btn-edit" class="btn btn-primary">Chỉnh sửa</a>
                    <a href="/Products" class="btn btn-secondary ml-2">Quay lại</a>
                </p>

                <!-- SKU TABLE -->
                <h4 class="mt-4">Thông tin lưu kho</h4>
                <hr />

                <div id="sku-empty" style="display:none;">
                    <em>Không có sản phẩm nào.</em>
                </div>

                <table id="sku-table" class="table table-bordered table-sm" style="display:none;">
                    <thead>
                        <tr>
                            <th>Mã sản phẩm</th>
                            <th>Màu sắc</th>
                            <th>Kích cỡ</th>
                            <th class="text-left">Số lượng</th>
                            <th class="text-left">Giá (VNĐ)</th>
                        </tr>
                    </thead>
                    <tbody id="sku-body"></tbody>
                </table>
            </div>

            <!-- RIGHT: IMAGE GALLERY -->
            <div class="col-md-4">
                <h4>Ảnh sản phẩm</h4>
                <hr />

                <div id="image-empty">
                    <em>Không có ảnh.</em>
                </div>

                <div id="image-section" style="display:none;">
                    <div class="mb-3 text-center">
                        <a href="#" class="open-lightbox" onclick="return false;">
                            <img id="mainPreview"
                                 src=""
                                 class="img-fluid img-thumbnail"
                                 style="max-height:320px; width:100%; object-fit:contain;" />
                        </a>
                    </div>

                    <div id="thumb-list" class="d-flex flex-wrap"></div>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- MODAL LIGHTBOX -->
<div class="modal fade" id="productLightbox" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 position-relative">
                <button type="button" class="close position-absolute text-white"
                        style="right:12px; top:6px; z-index:1051"
                        data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" style="font-size:28px;">&times;</span>
                </button>

                <div id="lightboxInner"
                     class="text-center"
                     style="background:#000; padding:12px; border-radius:6px;">

                    <img id="lightboxImage"
                         src=""
                         style="max-width:100%; max-height:75vh; object-fit:contain;" />

                    <div id="lightboxCaption" class="mt-2 text-white small"></div>

                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <button id="lightPrev" class="btn btn-sm btn-light">‹ Trước</button>
                        <div><span id="lightIndex" class="text-white small"></span></div>
                        <button id="lightNext" class="btn btn-sm btn-light">Tiếp ›</button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
$(document).ready(function () {

    //Chuẩn bị dữ liệu
    const productId = @ViewBag.Id;
    let images = [];
    let currentIndex = 0;

    loadDetails();

    function loadDetails() {
        $.ajax({
            url: "/Products/DetailsProduct/" + productId,
            type: "GET",
            success: function (p) {

                if (!p) { alert("Không tìm thấy sản phẩm!"); return; }

                // ========== TEXT ==========
                $("#d-category").text(p.CategoryName ?? "-");
                $("#d-title").text(p.Title);
                $("#d-description").text(p.Description ?? "Không có mô tả");
                $("#d-status").text(p.Status ?? "Không rõ");
                $("#btn-edit").attr("href", "/Products/Edit/" + p.Id);

                // ========== SKU TABLE ==========
                if (!p.Skus || p.Skus.length === 0) {
                    $("#sku-empty").show();
                    $("#sku-table").hide();
                } else {
                    $("#sku-body").empty();
                    p.Skus.forEach(s => {
                        $("#sku-body").append(`
                            <tr>
                                <td>${s.Sku}</td>
                                <td>${s.Color || "-"}</td>
                                <td>${s.Size || "-"}</td>
                                <td class="text-left">${s.Quantity}</td>
                                <td class="text-left">${s.Price.toLocaleString("vi-VN")}</td>
                            </tr>
                        `);
                    });
                    $("#sku-table").show();
                    $("#sku-empty").hide();
                }

                // ========== IMAGE GALLERY ==========
                if (!p.Images || p.Images.length === 0) {
                    $("#image-empty").show();
                    $("#image-section").hide();
                    return;
                }

                $("#image-empty").hide();
                $("#image-section").show();

                images = p.Images.map((img, i) => ({
                    url: img.Url,
                    caption: "Ảnh #" + (i + 1)
                }));

                $("#mainPreview").attr("src", images[0].url);

                $("#thumb-list").empty();
                images.forEach((img, i) => {
                    $("#thumb-list").append(`
                        <div style="margin:4px; cursor:pointer;">
                            <img src="${img.url}"
                                 class="img-thumbnail thumb-img"
                                 style="width:120px; height:90px; object-fit:cover;"
                                 data-index="${i}" />
                        </div>
                    `);
                });

                // ===== CLICK THUMBNAIL
                $(".thumb-img").click(function () {
                    currentIndex = parseInt($(this).data("index"));
                    $("#mainPreview").attr("src", images[currentIndex].url);
                });

                // ===== MAIN PREVIEW OPEN LIGHTBOX
                $(".open-lightbox").click(function (e) {
                    e.preventDefault();
                    openLightbox(0);
                });

            },
            error: function () {
                alert("Lỗi khi tải dữ liệu!");
            }
        });
    }

    // ========== LIGHTBOX LOGIC ==========
    function openLightbox(index) {
        if (images.length === 0) return;

        currentIndex = index;
        const img = images[currentIndex];

        $("#lightboxImage").attr("src", img.url);
        $("#lightboxCaption").text(img.caption);
        $("#lightIndex").text((currentIndex + 1) + " / " + images.length);

        $("#productLightbox").modal("show");
    }

    function showNext() {
        currentIndex = (currentIndex + 1) % images.length;
        openLightbox(currentIndex);
    }

    function showPrev() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        openLightbox(currentIndex);
    }

    $("#lightNext").click(showNext);
    $("#lightPrev").click(showPrev);

    $(document).keydown(function (e) {
        if (!$("#productLightbox").hasClass("show")) return;
        if (e.key === "ArrowRight") showNext();
        if (e.key === "ArrowLeft") showPrev();
        if (e.key === "Escape") $("#productLightbox").modal("hide");
    });

    $("#productLightbox").on('hidden.bs.modal', function () {
        if (images.length > 0) {
            $("#mainPreview").attr("src", images[currentIndex].url);
        }
    });

});
    </script>
}
