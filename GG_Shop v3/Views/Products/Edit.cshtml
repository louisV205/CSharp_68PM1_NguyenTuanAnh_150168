@{
    ViewBag.Title = "Edit Product";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
}

<div class="content-page" id="edit-product-page" data-product-id="@ViewBag.Id">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0">Chỉnh sửa sản phẩm</h4>
                    </div>
                    <div class="card-body">
                        @using (Html.BeginForm("Edit", "Products", FormMethod.Post, new { enctype = "multipart/form-data", id = "editProductForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="productId" name="Id" value="@ViewBag.Id" />

                            <div class="form-group">
                                <label>Tên sản phẩm</label>
                                <input type="text" id="Title" name="Title" class="form-control" required />
                            </div>

                            <div class="form-group">
                                <label>Danh mục</label>
                                <select id="Category_Id" name="Category_Id" class="form-control">
                                    <option value="">Chọn danh mục</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Mô tả</label>
                                <textarea id="Description" name="Description" rows="4" class="form-control"></textarea>
                            </div>

                            <div class="form-group">
                                <label>Trạng thái</label>
                                <select id="Status" name="Status" class="form-control">
                                    <option value="">Chọn trạng thái</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Ảnh sản phẩm</label>
                                <div id="existing-images-row" class="row"></div>
                                <hr />
                                <label>Upload ảnh mới</label>
                                <input type="file" name="newImages" id="newImages" accept="image/*" multiple class="form-control" />
                                <small class="form-text text-muted">Bạn có thể chọn nhiều ảnh.</small>
                                <div id="previewNewImages" class="mt-2 d-flex flex-wrap"></div>
                            </div>

                            <hr />
                            <h5 class="mt-4">Thông tin lưu kho</h5>
                            <table class="table table-sm table-bordered" id="skuTable">
                                <thead>
                                    <tr>
                                        <th>Mã sản phẩm</th>
                                        <th>Màu sắc</th>
                                        <th>Kích cỡ</th>
                                        <th>Số lượng</th>
                                        <th>Giá (VNĐ)</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="skuBody"></tbody>
                            </table>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addSku">+ Thêm SKU</button>

                            <div class="mt-4">
                                <button type="submit" id="btnSave" class="btn btn-primary">Lưu thay đổi</button>
                                @Html.ActionLink("Quay lại danh sách", "Index", null, new { @class = "btn btn-secondary ml-2" })
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            const productId = $('#edit-product-page').data('product-id');

            // Preview ảnh mới
            $('#newImages').on('change', function () {
                const preview = $('#previewNewImages').empty();
                Array.from(this.files).forEach(file => {
                    const fr = new FileReader();
                    fr.onload = e => {
                        preview.append(`<img src="${e.target.result}" style="width:120px;height:90px;object-fit:cover;border:1px solid #ddd;padding:2px;margin:6px;" />`);
                    };
                    fr.readAsDataURL(file);
                });
            });

            // Thêm SKU
            $('#addSku').on('click', function () {
                const idx = $('#skuBody tr').length;
                $('#skuBody').append(`
                    <tr>
                        <td><input type="text" name="skus[${idx}].Sku" class="form-control" /></td>
                        <td><input type="text" name="skus[${idx}].Color" class="form-control" /></td>
                        <td><input type="text" name="skus[${idx}].Size" class="form-control" /></td>
                        <td><input type="number" name="skus[${idx}].Quantity" class="form-control" /></td>
                        <td><input type="number" name="skus[${idx}].Price" class="form-control" /></td>
                        <td class="text-center"><button type="button" class="btn btn-sm btn-danger remove-row">×</button></td>
                    </tr>
                `);
            });

            // Xóa SKU
            $(document).on('click', '.remove-row', function () {
                $(this).closest('tr').remove();
            });

            // Đồng bộ ảnh đại diện và xóa
            function wireUpImageControls() {
                $('.delete-checkbox').on('change', function () {
                    if (this.checked) $(`.main-radio[value="${this.value}"]`).prop('checked', false);
                });
                $('.main-radio').on('change', function () {
                    if (this.checked) $(`.delete-checkbox[value="${this.value}"]`).prop('checked', false);
                });
            }

            // Trước khi submit
            function sanitizeBeforeSubmit() {
                const main = $('.main-radio:checked').val();
                if (main) {
                    const delChk = $(`.delete-checkbox[value="${main}"]`);
                    if (delChk.length && delChk.is(':checked')) delChk.prop('checked', false);
                }
            }

            // Submit AJAX
            $('#editProductForm').on('submit', function (ev) {
                ev.preventDefault();
                sanitizeBeforeSubmit();

                const fd = new FormData(this);
                $('#btnSave').prop('disabled', true).text('Đang lưu...');

                $.ajax({
                    url: '/Products/EditAjax',
                    type: 'POST',
                    data: fd,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        $('#btnSave').prop('disabled', false).text('Lưu thay đổi');
                        if (res && res.success) {
                            window.location.href = res.redirectUrl || '/Products/Index';
                        } else {
                            alert('Lỗi khi lưu: ' + (res.message || 'Không rõ'));
                        }
                    },
                    error: function () {
                        alert("Lỗi hệ thống!");
                    }
                });
            });

            // Load dữ liệu sản phẩm
            function loadProductData() {
                $.getJSON('/Products/EditProduct/' + productId).done(function (data) {
                    if (!data) { alert("Không tìm thấy sản phẩm"); return; }

                    $('#Title').val(data.Title);
                    $('#Description').val(data.Description);

                    // Danh mục
                    const $cat = $('#Category_Id').empty().append('<option value="">Chọn danh mục</option>');
                    if (Array.isArray(data.Categories)) {
                        data.Categories.forEach(c => {
                            const selected = c.Id === data.Category_Id ? 'selected' : '';
                            $cat.append(`<option value="${c.Id}" ${selected}>${c.Name}</option>`);
                        });
                    }

                    // Trạng thái
                    const $status = $('#Status').empty().append('<option value="">Chọn trạng thái</option>');
                    if (Array.isArray(data.StatusList)) {
                        data.StatusList.forEach(s => {
                            const selected = s === data.Status ? 'selected' : '';
                            $status.append(`<option value="${s}" ${selected}>${s}</option>`);
                        });
                    }

                    // Ảnh
                    const $imgRow = $('#existing-images-row').empty();
                    if (!data.Images || data.Images.length === 0) {
                        $imgRow.append('<div class="col-12 text-muted">Chưa có ảnh.</div>');
                    } else {
                        data.Images.forEach(img => {
                            const checked = img.Is_Main ? 'checked' : '';
                            $imgRow.append(`
                            <div class="col-3 mb-3">
                                <div class="card">
                                    <img src="${img.Url}" class="card-img-top" style="height:120px; object-fit:cover;" />
                                    <div class="card-body p-2">
                                        <div class="form-check">
                                            <input class="form-check-input main-radio" type="radio" name="mainImageId" value="${img.Id}" ${checked} />
                                            <label class="form-check-label">Ảnh đại diện</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input delete-checkbox" type="checkbox" name="deleteImages" value="${img.Id}" />
                                            <label class="form-check-label text-danger">Xóa</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `);
                        });
                        wireUpImageControls();
                    }

                    // SKU
                    const $skuBody = $('#skuBody').empty();
                    if (!data.Skus || data.Skus.length === 0) {
                        $skuBody.append('<tr><td colspan="6" class="text-muted text-center">Chưa có SKU.</td></tr>');
                    } else {
                        data.Skus.forEach((s, i) => {
                            $skuBody.append(`
                            <tr>
                                <td>
                                    <input type="hidden" name="skus[${i}].Id" value="${s.Id}" />
                                    <input type="hidden" name="skus[${i}].Product_Id" value="${data.Id}" />
                                    <input type="text" name="skus[${i}].Sku" value="${s.Sku}" class="form-control" />
                                </td>
                                <td><input type="text" name="skus[${i}].Color" value="${s.Color}" class="form-control" /></td>
                                <td><input type="text" name="skus[${i}].Size" value="${s.Size}" class="form-control" /></td>
                                <td><input type="number" name="skus[${i}].Quantity" value="${s.Quantity}" class="form-control" /></td>
                                <td><input type="number" name="skus[${i}].Price" value="${s.Price}" class="form-control" /></td>
                                <td class="text-center"><button type="button" class="btn btn-sm btn-danger remove-row">×</button></td>
                            </tr>
                        `);
                        });
                    }
                }).fail(function () {
                    alert("Lỗi khi tải dữ liệu sản phẩm!");
                });
            }

            // Gọi load dữ liệu khi trang mở
            if (productId) {
                loadProductData();
            }
        });
    </script>
}