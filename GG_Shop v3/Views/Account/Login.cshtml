@{
    Layout = "~/Views/Shared/_Layout_Login.cshtml";
    ViewBag.Title = "Đăng nhập";
}

<div class="login-wrapper">
    <div class="login-header">
        <h2>Đăng Nhập</h2>
        <p>Nhập thông tin tài khoản</p>
    </div>

    @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "loginForm", @class = "login-form" }))
    {
        @Html.AntiForgeryToken()

        <div class="input-group">
            <div class="input-wrapper">
                <label for="Email" class="sr-only">Email address</label>
                <input id="Email" name="Email" type="email" class="form-control" placeholder="Địa chỉ Email" required />
            </div>
            <span class="error-message" id="emailError" aria-live="polite"></span>
        </div>

        <div class="input-group">
            <div class="input-wrapper password-wrapper">
                <label for="Password" class="sr-only">Password</label>
                <input id="Password" name="Password" type="password" class="form-control" placeholder="Mật khẩu" required />
                <button class="password-toggle" type="button" aria-label="Toggle password visibility">
                    <i class="fa-solid fa-eye"></i>
                    <i class="fa-solid fa-eye-slash"></i>
                </button>
            </div>
            <span class="error-message" id="passwordError" aria-live="polite"></span>
        </div>

        <div class="form-options">
            <label class="remember-wrapper">
                <input id="RememberMe" name="RememberMe" type="checkbox" />
                <span>Ghi nhớ</span>
            </label>
            <a class="forgot-password" href="@Url.Action("ForgotPassword", "Account")">Quên mật khẩu</a>
        </div>

        <div class="input-group mt-3">
            <button type="submit" class="login-btn" id="loginSubmit">
                <span class="btn-text">Đăng Nhập</span>
                <span class="btn-spinner hidden" aria-hidden="true"></span>
            </button>
        </div>
    }

    <div class="login-card-footer">
        <small>Chưa có tài khoản? <a href="@Url.Action("Register", "Account")">Tạo tài khoản</a></small>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/js/Login.js"></script>
}