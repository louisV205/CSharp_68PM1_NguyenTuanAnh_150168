@model GG_Shop_v3.Models.Category

@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
}

<div class="content-page">
    <div class="container-fluid">
        <h3>Chi tiết danh mục</h3>

        <div id="detailsContainer">
            <hr />
            <dl class="dl-horizontal">
                <dt>Tên danh mục</dt>
                <dd id="detailName">@Html.DisplayFor(model => model.Name)</dd>

                <dt>Mô tả danh mục</dt>
                <dd id="detailDescription">@Html.DisplayFor(model => model.Description)</dd>
            </dl>
        </div>

        <div class="mt-3">
            <a href="@Url.Action("Edit", "Categories", new { id = Model.Id })" class="btn btn-primary mr-2">Sửa</a>
            <a href="@Url.Action("Index", "Categories")" class="btn btn-secondary">Quay về danh sách</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var categoryId = @Model.Id;

            // Nếu bạn muốn load dữ liệu chi tiết qua AJAX
            $.ajax({
                url: '@Url.Action("GetCategoryDetails", "Categories")',
                type: 'GET',
                data: { id: categoryId },
                success: function(result) {
                    if(result.success === false) {
                        alert(result.message || "Không tìm thấy danh mục");
                    } else {
                        // Cập nhật chi tiết lên view
                        $('#detailName').text(result.Name);
                        $('#detailDescription').text(result.Description || '');
                    }
                },
                error: function(xhr) {
                    alert("Có lỗi khi tải dữ liệu: " + xhr.responseText);
                }
            });
        });
    </script>
}
