@using GG_Shop_v3.Models
@{
    ViewBag.Title = "Danh sách các danh mục";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
}

<div class="content-page">
    <div class="container-fluid">
        <h2>Danh mục</h2>
        <a href="@Url.Action("Create", "Categories")" class="btn btn-danger mt-2">
            Tạo danh mục
        </a>

        <!-- Thanh tìm kiếm realtime -->
        <div class="form-group mt-3 col-md-4">
            <input type="text" id="searchInput" class="form-control form-control-sm"
                   placeholder="Tìm kiếm theo chữ cái đầu tiên..." />
        </div>

        <!-- Table danh mục -->
        <table class="table" id="categoryTable">
            <thead>
                <tr>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th class="text-right">Hành động</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadCategories();

            // Tìm kiếm realtime
            $("#searchInput").on("keyup", function () {
                loadCategories($(this).val());
            });

            // Load danh sách danh mục
            function loadCategories(search = "") {
                $.get('@Url.Action("GetCategories", "Categories")', { search: search })
                    .done(function (data) {
                        var tbody = $("#categoryTable tbody");
                        tbody.empty();

                        if (data.length === 0) {
                            tbody.append('<tr><td colspan="3" class="text-center">Không tìm thấy danh mục nào.</td></tr>');
                            return;
                        }

                        $.each(data, function (i, item) {
                            var row = '<tr>' +
                                '<td>' + item.Name + '</td>' +
                                '<td>' + (item.Description || '') + '</td>' +
                                '<td class="text-right">' +
                                '<a href="@Url.Action("Edit", "Categories")?id=' + item.Id + '" class="badge badge-success mr-2" title="Sửa"><i class="fas fa-pencil-alt"></i></a>' +
                                '<a href="@Url.Action("Details", "Categories")?id=' + item.Id + '" class="badge badge-info mr-2" title="Chi tiết"><i class="fas fa-eye"></i></a>' +
                                '<a href="#" class="badge bg-warning deleteBtn" data-id="' + item.Id + '" title="Xóa"><i class="fas fa-trash-alt"></i></a>' +
                                '</td>' +
                                '</tr>';
                            tbody.append(row);
                        });
                    })
                    .fail(function (xhr) {
                        alert("Lỗi tải dữ liệu. Xem console.");
console.log(xhr.responseText);
                    });
            }


            $(document).on("click", ".deleteBtn", function (e) {
                e.preventDefault();
                var id = $(this).data("id");

                if (confirm("Bạn có chắc chắn muốn xóa danh mục này?")) {
                    $.ajax({
                        url: '@Url.Action("DeleteCategory", "Categories")',
                        type: 'POST',
                        data: { id: id },
                        success: function (result) {
                            alert(result.message || (result.success ? "Xóa thành công!" : "Xóa thất bại"));
                            if (result.success) {
                                loadCategories($("#searchInput").val());
                            }
                        },
                        error: function () {
                            alert("Lỗi server khi xóa.");
                        }
                    });
                }
            });
        });
    </script>
} 