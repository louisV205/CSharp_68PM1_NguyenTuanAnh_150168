@model GG_Shop_v3.Models.Category
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout_admin.cshtml";
}

<div class="content-page">
    <div class="container-fluid">
        <h3>Chỉnh sửa danh mục</h3>

        <form id="editCategoryForm">
            @Html.HiddenFor(model => model.Id)

            <div class="form-horizontal">
                <div class="form-group">
                    @Html.LabelFor(model => model.Name, "Tên danh mục", htmlAttributes: new { @class = "control-label col-md-2" })
                    <div class="col-md-4">
                        @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                        <span class="text-danger field-validation-error" data-valmsg-for="Name"></span>
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Description, "Mô tả danh mục", htmlAttributes: new { @class = "control-label col-md-2" })
                    <div class="col-md-4">
                        @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control" } })
                        <span class="text-danger field-validation-error" data-valmsg-for="Description"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <button type="submit" class="btn btn-primary mr-2">Lưu</button>
                        <a href="@Url.Action("Index","Categories")" class="btn btn-secondary">Quay về danh sách</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            $('#editCategoryForm').submit(function (e) {
                e.preventDefault();

                // Xóa thông báo lỗi cũ
                $('.field-validation-error').text('');

                // Kiểm tra validation client-side (nếu có jquery.validate)
                if (!$(this).valid()) {
                    return;
                }

                var formData = $(this).serialize();

                $.ajax({
                    url: '@Url.Action("UpdateCategory", "Categories")',
                    type: 'POST',
                    data: formData,
                    success: function (result) {
                        if (result && result.success) {
                            alert(result.message || 'Cập nhật thành công!');
                            window.location.href = '@Url.Action("Index", "Categories")';
                        } else {
                            alert(result.message || 'Có lỗi xảy ra');

                            // Nếu server trả về danh sách lỗi chi tiết
                            if (result && result.errors && result.errors.length > 0) {
                                $('.field-validation-error').eq(0).text(result.errors[0]); // Name
                                if (result.errors.length > 1) {
                                    $('.field-validation-error').eq(1).text(result.errors[1]); // Description
                                }
                            }
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr.responseText);
                        alert("Lỗi server. Vui lòng kiểm tra console để biết chi tiết.");
                    }
                });
            });
        });
    </script>
}